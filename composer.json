{
    "name": "albatech/ssms",
    "description": "School Management System — PHP backend, modular monolith architecture",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "php-di/php-di": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "Core/",
            "Modules\\": "Modules/"
        },
        "files": [
            "Core/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
