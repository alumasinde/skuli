# Application
APP_NAME=SchoolMS
APP_ENV=development
APP_DEBUG=true
APP_URL=http://ssms.highway.localhost

# Database (PDO/MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=SCHOOL-DEFAULT
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# JWT
# Generate a real secret with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=change-this-to-a-random-64-char-hex-string

# Rate limiting (requests per window)
RATE_LIMIT_AUTH=10
RATE_LIMIT_AUTH_WINDOW=60
RATE_LIMIT_API=300
RATE_LIMIT_API_WINDOW=60
